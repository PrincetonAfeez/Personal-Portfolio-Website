DJANGO_SETTINGS_MODULE=portfolio_site.settings.dev
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=sqlite:///db.sqlite3
CANONICAL_URL=http://127.0.0.1:8000
LOG_LEVEL=INFO
CONTACT_NOTIFICATION_EMAIL=
CONTACT_RATE_LIMIT_WINDOW=900
CONTACT_RATE_LIMIT_MAX=5
# Only true behind a trusted reverse proxy that sets X-Forwarded-For safely.
CONTACT_TRUST_X_FORWARDED_FOR=False

# Public footer / contact page (use your real profiles in production).
PUBLIC_GITHUB_URL=https://github.com/
PUBLIC_LINKEDIN_URL=https://www.linkedin.com/
PUBLIC_CONTACT_EMAIL=hello@example.com

